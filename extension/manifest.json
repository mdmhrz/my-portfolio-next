{
  "manifest_version": 3,
  "name": "mhrazu.com Job Tracker",
  "version": "1.0.0",
  "description": "Save job postings from LinkedIn, Greenhouse, Lever, Workday, and other career sites straight into the mhrazu.com Job Tracker dashboard.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "http://localhost:3000/*",
    "https://mhrazu.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/view/*"],
      "js": ["shared/scrape-utils.js", "content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.greenhouse.io/*"],
      "js": ["shared/scrape-utils.js", "content/greenhouse.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://jobs.lever.co/*"],
      "js": ["shared/scrape-utils.js", "content/lever.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.myworkdayjobs.com/*"],
      "js": ["shared/scrape-utils.js", "content/workday.js"],
      "run_at": "document_idle"
    }
  ]
}
