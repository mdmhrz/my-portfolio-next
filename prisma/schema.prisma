datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- Better-Auth Models ---
model User {
  id               String      @id @default(uuid())
  name             String
  email            String      @unique
  emailVerified    Boolean
  image            String?
  role             String?     @default("user") // We can set default to "user", and the admin account will have "admin"
  twoFactorEnabled Boolean?    @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  sessions         Session[]
  accounts         Account[]
  twoFactors       TwoFactor[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// Admin-account 2FA (TOTP), added by better-auth's `twoFactor` plugin.
// Field names/shape are dictated by the plugin — do not rename.
model TwoFactor {
  id                      String    @id @default(uuid())
  secret                  String
  backupCodes             String
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified                Boolean?
  failedVerificationCount Int?      @default(0)
  lockedUntil             DateTime?

  @@map("two_factor")
}

// --- CMS Portfolio Models ---

// All hero-facing text lives here. Contact info (email/social links) still
// comes from Profile — Profile's own name/designation remain in use elsewhere
// (About page, Contact page JSON-LD, Footer) so they aren't removed there.
model Banner {
  id            String   @id @default("singleton")
  headline      String   @default("") // Hero headline (person's name/title as shown in the hero)
  subtitle      String   @default("") // Hero eyebrow/subtitle (job title as shown in the hero)
  description   String // Hero tagline/pitch
  backgroundImg String? // Static image shown when backgroundTemplate = "none" (falls back to solid color)
  backgroundAlt String? // Alt text for background image
  chips         String[] // e.g., ["Frontend Dev @ Xgenious", "Docker · AWS"]
  ctaLabel      String   @default("View work")
  ctaHref       String   @default("#work")

  // Template system — three independent axes, freely mixable.
  backgroundTemplate String  @default("none") // "none" | "lattice" | "particles" | "wave"
  layoutTemplate     String  @default("signature") // "signature" | "showcase"
  animationTemplate  String  @default("signature") // "signature" | "fade"
  heroImage          String? // Optional showcase image some layouts use instead of the code card
  heroImageAlt       String?
  showcaseImageSide  String  @default("left") // "left" | "right" — which side the showcase image sits on (desktop)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banner")
}

model Experience {
  id          String    @id @default(uuid())
  company     String
  role        String
  location    String
  timeline    String // e.g., "Jul 2025 — Present"
  description String
  logo        String? // Company logo URL
  logoAlt     String? // Alt text for company logo
  order       Int       @default(0)
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("experience")
}

model Project {
  id                String      @id @default(uuid())
  slug              String      @unique
  title             String
  subtitle          String
  category          String
  role              String?
  company           String?
  timeline          String?
  desc              String
  fullDesc          String
  tech              String[]
  features          String[]
  contributions     String[]
  live              String?
  image             String
  imageAlt          String? // Alt text for image
  featured          Boolean     @default(false) // Show in CaseStudies hero section
  span              String? // For UI grid layout e.g. "lg:col-span-7"
  architectureTitle String?
  architectureDesc  String?
  architectureTree  String?
  metrics           Json? // List of metrics e.g. [{"label":"Deployment","value":"AWS EC2"}]
  order             Int         @default(0)
  experienceId      String?
  experience        Experience? @relation(fields: [experienceId], references: [id], onDelete: SetNull)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("project")
}

model Cta {
  id          String   @id @default("singleton")
  headline    String   @default("Let's build something solid.")
  subtext     String   @default("Frontend & full-stack engineering — from Next.js interfaces to Node & Go services. Open to freelance work, consulting, and full-time roles.")
  buttonLabel String   @default("Get in touch")
  buttonHref  String   @default("#contact")
  updatedAt   DateTime @updatedAt

  @@map("cta")
}

model Footer {
  id                String   @id @default("singleton")
  bio               String? // null = fall back to Profile.bio
  availabilityBadge String   @default("Open for roles")
  availabilityText  String   @default("Currently accepting freelance contracts, SaaS consulting, and full-time frontend/full-stack engineering roles.")
  location          String   @default("Remote / UTC+6")
  primaryStack      String   @default("React, Next.js, Go")
  copyrightName     String   @default("MHR.DEV")
  updatedAt         DateTime @updatedAt

  @@map("footer")
}

model NavLink {
  id           String   @id @default(uuid())
  label        String
  href         String
  order        Int      @default(0)
  showInNav    Boolean  @default(true)
  showInFooter Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("nav_link")
}

model SectionConfig {
  id      String  @id @default(uuid())
  key     String  @unique // "hero" | "techMarquee" | "journey" | "experience" | "tools" | "caseStudies" | "homepageBlogs" | "testimonials" | "cta" | "contact"
  visible Boolean @default(true)
  order   Int     @default(0)

  @@map("section_config")
}

model Message {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  thread    Thread?

  @@map("message")
}

// --- Gmail Inbox Integration ---
// Single-admin Gmail account connection used to send/receive real email
// from the dashboard. Refresh token is encrypted at rest (see lib/crypto.ts).
model GmailAccount {
  id                   String    @id @default(uuid())
  userId               String    @unique
  email                String
  accessToken          String    @db.Text
  refreshTokenEnc      String    @db.Text
  accessTokenExpiresAt DateTime
  scope                String
  historyId            String?
  watchExpiration      DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("gmail_account")
}

// A conversation with one external contact — either started by a portfolio
// contact-form submission (messageId set) or by the admin composing a new
// email from the dashboard (messageId null).
model Thread {
  id            String         @id @default(uuid())
  gmailThreadId String?        @unique
  contactEmail  String
  contactName   String?
  subject       String?
  messageId     String?        @unique
  message       Message?       @relation(fields: [messageId], references: [id], onDelete: SetNull)
  unread        Boolean        @default(true)
  lastMessageAt DateTime       @default(now())
  emails        EmailMessage[]
  createdAt     DateTime       @default(now())

  @@map("thread")
}

// One actual email (sent or received) within a Thread.
model EmailMessage {
  id             String       @id @default(uuid())
  threadId       String
  thread         Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  gmailMessageId String?      @unique
  rfcMessageId   String? // RFC822 Message-ID header, needed for correct In-Reply-To threading
  direction      String // "inbound" | "outbound"
  fromEmail      String
  toEmail        String
  subject        String?
  bodyHtml       String       @db.Text
  snippet        String?
  attachments    Attachment[]
  sentAt         DateTime     @default(now())
  createdAt      DateTime     @default(now())

  @@map("email_message")
}

model Attachment {
  id             String       @id @default(uuid())
  emailMessageId String
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  fileName       String
  mimeType       String
  url            String
  size           Int?

  @@map("attachment")
}

model Blog {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  content         String // Markdown string
  excerpt         String
  coverImage      String?
  coverImageAlt   String?
  category        String?
  tags            String[]
  featured        Boolean  @default(false)
  published       Boolean  @default(false)
  readingTime     Int      @default(0)
  views           Int      @default(0)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("blog")
}

// --- Profile / Singleton Models ---
// Single source of truth for everything about the person: identity, contact,
// and social links. Any public section that shows a name/photo/email/social
// link reads it from here — never hardcode or duplicate these elsewhere.
model Profile {
  id           String   @id @default("singleton")
  name         String
  designation  String // e.g. "Full-Stack Developer"
  bio          String // Short bio for Journey/Hero section
  longBio      String? // Extended bio paragraph
  avatarUrl    String? // Profile photo (Cloudinary URL)
  avatarAlt    String? // Alt text for avatar
  resumeUrl    String? // Public PDF link
  location     String?
  availability String? // e.g. "Open to work"
  email        String?
  whatsapp     String? // Public contact whatsapp number/link
  github       String?
  linkedin     String?
  facebook     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("profile")
}

model SiteSettings {
  id String @id @default("singleton")

  // SITE LOGO — logoUrl/logoAlt shown on a light background, logoUrlDark/logoAltDark
  // (optional) shown on a dark background. Falls back to the built-in mark if unset.
  logoUrl     String?
  logoAlt     String?
  logoUrlDark String?
  logoAltDark String?

  // FAVICON — replaces the built-in browser-tab icon when set.
  faviconUrl String?

  // FONTS
  fontType      String?  @default("default") // "default" | "google" | "custom"
  fontName      String?  @default("Satoshi")
  fontWeights   String[] @default(["400", "500", "700", "900"])
  customFontUrl String?  @db.Text // URL to custom font (Cloudinary)

  // COLORS — two independent sets. null = use built-in globals.css theme (restore target).
  // Shape: { mode: "simple"|"themes"|"advanced", accentColor, themePreset, customPalette }
  publicColors    Json? // Public site (/, /blogs, …)
  dashboardColors Json? // Admin dashboard (/admin/*)

  // COLORS (legacy flat fields — retained for back-compat, no longer read/written)
  colorMode     String? @default("simple")
  accentColor   String? @default("#000000")
  themePreset   String? @default("default")
  customPalette Json?

  // HOMEPAGE BLOG SECTION — controls the "Featured Articles" slider on the landing page
  // Visibility now lives in SectionConfig (key="homepageBlogs") alongside every other section.
  homepageBlogTitle    String? // custom heading; null = default
  homepageBlogSubtitle String? // custom subheading; null = default
  homepageBlogTemplate String  @default("standard") // "standard" | "overlay" | "minimal"

  // HOMEPAGE TESTIMONIALS SECTION — controls the testimonials section on the landing page
  // Visibility now lives in SectionConfig (key="testimonials") alongside every other section.
  homepageTestimonialsTitle     String?
  homepageTestimonialsSubtitle  String?
  homepageTestimonialsTemplate  String  @default("carousel") // "carousel" | "scattered" | "autoslide" | "bento"
  homepageTestimonialsStat      String? // e.g. "12+" — shown only by the bento preset
  homepageTestimonialsStatLabel String? // e.g. "Happy Clients"
  homepageTestimonialsCtaText   String? // e.g. "Get in Touch"
  homepageTestimonialsCtaLink   String? // defaults to "/contact" if unset

  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model Testimonial {
  id             String   @id @default(uuid())
  name           String
  role           String?
  company        String?
  quote          String   @db.Text
  avatarUrl      String?
  avatarAlt      String?
  rating         Int? // 1-5, optional
  videoUrl       String? // Optional video testimonial (Preset A "Carousel" video card)
  highlight      String? // Short metric badge, e.g. "8X" (Preset C "Bento Stats")
  highlightLabel String? // Metric caption, e.g. "Increase in conversion rate"
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("testimonial")
}

model Skill {
  id        String   @id @default(uuid())
  name      String
  category  String // "frontend" | "backend" | "devops" | "tools"
  icon      String? // icon identifier or SVG string / image URL
  iconAlt   String? // Alt text for skill icon
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("skill")
}

// First-party, privacy-friendly traffic tracking (public pages only). Powers the
// dashboard's Visitors / Page Views / Resume Downloads metrics — no third-party API.
model AnalyticsEvent {
  id        String   @id @default(uuid())
  type      String   @default("pageview") // "pageview" | "resume_download"
  path      String?
  referrer  String?
  country   String? // from the x-vercel-ip-country header when available
  visitorId String? // anonymous client id (localStorage) for unique-visitor counts
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@map("analytics_event")
}

// --- Job Tracker ---
// Personal CRM for job applications, since sources vary wildly (LinkedIn,
// referrals, Google Forms, hard copy, …) and no single API can capture them all.
model JobApplication {
  id                 String           @id @default(uuid())
  company            String
  position           String
  companyLogo        String?
  jobUrl             String?
  source             String // "linkedin" | "facebook" | "google_form" | "referral" | "friend" | "email" | "career_site" | "hard_copy" | "other"
  applicationType    String // "easy_apply" | "external_website" | "email" | "google_form" | "hard_copy" | "referral"
  status             String           @default("saved") // "found" | "saved" | "preparing" | "applied" | "assessment" | "interview" | "offer" | "rejected"
  deadline           DateTime?
  salaryMin          Int?
  salaryMax          Int?
  salaryCurrency     String?
  location           String?
  workMode           String? // "remote" | "hybrid" | "onsite"
  resumeVersion      String?
  coverLetterVersion String?
  notes              String?          @db.Text
  appliedAt          DateTime?
  gmailThreadId      String? // manual link to a Gmail thread for this application (Phase 3)
  calendarEventId    String? // Google Calendar event id for a scheduled interview (Phase 4)
  calendarEventLink  String? // htmlLink to open the event in Google Calendar
  order              Int              @default(0)
  events             JobStatusEvent[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@map("job_application")
}

// Append-only history — every status change and manual note, so the
// pipeline board can show how a job got to its current state, not just the state itself.
model JobStatusEvent {
  id             String         @id @default(uuid())
  jobId          String
  job            JobApplication @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status         String
  note           String?
  source         String         @default("manual") // "manual" | "gmail" | "extension"
  gmailMessageId String?        @unique // dedup marker for events auto-created by the Gmail scan
  createdAt      DateTime       @default(now())

  @@map("job_status_event")
}

// A labeled Gmail message the job-tracker scan couldn't confidently match to
// an existing JobApplication (see src/lib/job-gmail-scan.ts) — surfaced in the
// dashboard for a one-click manual link instead of guessing wrong.
model UnmatchedJobEmail {
  id              String   @id @default(uuid())
  gmailMessageId  String   @unique
  gmailThreadId   String?
  fromEmail       String
  fromName        String?
  subject         String?
  snippet         String?
  suggestedStatus String // heuristic guess: "applied" | "assessment" | "interview" | "offer" | "rejected"
  receivedAt      DateTime
  createdAt       DateTime @default(now())

  @@map("unmatched_job_email")
}

model JobTrackerSettings {
  id         String   @id @default("singleton")
  gmailLabel String   @default("Jobs") // Gmail label the scan searches (q: "label:<this>")
  updatedAt  DateTime @updatedAt

  @@map("job_tracker_settings")
}

// --- Secrets Vault ---
// Single place for every credential/secret (API keys, DB URLs, SSH keys, env
// vars, ...). No typed columns on purpose — VaultField.type + encryptedValue
// is the only shape, so a new kind of secret never needs a migration.
model VaultItem {
  id          String             @id @default(uuid())
  title       String
  category    String // free-form: "Password" | "API" | "Database" | "Server" | "OAuth" | "Payment" | "Email" | "DNS" | "Cloud" | "Personal" | "Custom"
  description String?
  tags        String[]
  favorite    Boolean            @default(false)
  expiresAt   DateTime?
  fields      VaultField[]
  history     VaultItemHistory[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("vault_item")
}

// One labeled value on an item. `encryptedValue` is always ciphertext
// regardless of `type` — type only drives how the UI renders/masks it.
model VaultField {
  id             String    @id @default(uuid())
  vaultItemId    String
  vaultItem      VaultItem @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)
  label          String // e.g. "API Key", "Host", "Signing Secret"
  type           String    @default("password") // "text" | "password" | "url" | "textarea" | "json" | "env" | "number"
  encryptedValue String    @db.Text
  order          Int       @default(0)

  @@map("vault_field")
}

// Append-only snapshot taken on every edit, so a changed/rotated secret can
// be rolled back to what it was before.
model VaultItemHistory {
  id          String    @id @default(uuid())
  vaultItemId String
  vaultItem   VaultItem @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)
  snapshot    Json // [{ label, type, encryptedValue, order }, ...] as of changedAt
  changedAt   DateTime  @default(now())

  @@map("vault_item_history")
}

// Deliberately no relation to VaultItem — an audit trail must survive the
// item it refers to being deleted (the "deleted" entry itself would vanish
// on cascade otherwise), so vaultItemId is a plain, unconstrained reference.
model VaultAuditLog {
  id          String   @id @default(uuid())
  vaultItemId String?
  action      String // "created" | "opened" | "copied" | "updated" | "deleted" | "restored"
  fieldLabel  String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@map("vault_audit_log")
}

// Backs the reveal rate limit — DB-backed (not in-memory) since this app runs
// on Vercel's stateless serverless functions, where in-memory counters don't
// survive across invocations.
model VaultLoginAttempt {
  id        String   @id @default(uuid())
  success   Boolean
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("vault_login_attempt")
}
